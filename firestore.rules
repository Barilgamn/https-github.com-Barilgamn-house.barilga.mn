rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'info@barilga.mn' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      ) && request.auth.token.email_verified == true;
    }

    // Booth Booking Validation
    function isValidBoothBooking(data) {
      return data.keys().hasAll(['companyName', 'contactName', 'phone', 'boothId', 'createdAt'])
        && data.keys().size() == 5
        && data.companyName is string && data.companyName.size() > 0 && data.companyName.size() <= 200
        && data.contactName is string && data.contactName.size() > 0 && data.contactName.size() <= 100
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20
        && data.boothId is string && data.boothId.size() > 0 && data.boothId.size() <= 10
        && data.createdAt == request.time;
    }

    // Visitor Registration Validation
    function isValidVisitorRegistration(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'phone', 'email', 'createdAt'])
        && data.keys().size() == 5
        && data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 50
        && data.lastName is string && data.lastName.size() > 0 && data.lastName.size() <= 50
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100 && data.email.matches('.+@.+\\..+')
        && data.createdAt == request.time;
    }

    // Collection: Booth Bookings
    match /booth_bookings/{bookingId} {
      // Allow public creation
      allow create: if isValidId(bookingId) && isValidBoothBooking(incoming());
      
      allow read, list, delete: if isAdmin();
    }

    // Collection: Visitor Registrations
    match /visitor_registrations/{registrationId} {
      // Allow public creation
      allow create: if isValidId(registrationId) && isValidVisitorRegistration(incoming());
      
      allow read, list, delete: if isAdmin();
    }

    // Collection: Admins
    match /admins/{email} {
      allow read, get: if isSignedIn();
      allow write, delete: if isAdmin();
    }

    // Page View Validation
    function isValidPageView(data) {
      return data.keys().hasAll(['path', 'userAgent', 'createdAt'])
        && data.keys().size() == 3
        && data.path is string && data.path.size() > 0 && data.path.size() <= 200
        && data.userAgent is string && data.userAgent.size() >= 0 && data.userAgent.size() <= 500
        && data.createdAt == request.time;
    }

    // Exhibitor Validation
    function isValidExhibitor(data) {
      return data.keys().hasAll(['name', 'activity', 'booth', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.activity is string && data.activity.size() > 0 && data.activity.size() <= 200
        && data.booth is string && data.booth.size() > 0 && data.booth.size() <= 50
        && data.createdAt == request.time;
    }

    // Collection: Exhibitors
    match /exhibitors/{exhibitorId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidId(exhibitorId) && isValidExhibitor(incoming());
      allow delete: if isAdmin();
    }

    // Schedule Validation
    function isValidSchedule(data) {
      return data.keys().hasAll(['date', 'time', 'title', 'description', 'createdAt'])
        && data.keys().size() == 5
        && data.date is string && data.date.size() > 0 && data.date.size() <= 50
        && data.time is string && data.time.size() > 0 && data.time.size() <= 50
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() >= 0 && data.description.size() <= 1000
        && data.createdAt == request.time;
    }

    // Collection: Schedules
    match /schedules/{scheduleId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidId(scheduleId) && isValidSchedule(incoming());
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'time', 'title', 'description'])
                    && (!('date' in incoming()) || (incoming().date is string && incoming().date.size() > 0 && incoming().date.size() <= 50))
                    && (!('time' in incoming()) || (incoming().time is string && incoming().time.size() > 0 && incoming().time.size() <= 50))
                    && (!('title' in incoming()) || (incoming().title is string && incoming().title.size() > 0 && incoming().title.size() <= 200))
                    && (!('description' in incoming()) || (incoming().description is string && incoming().description.size() >= 0 && incoming().description.size() <= 1000));
      allow delete: if isAdmin();
    }

    // Collection: Page Views
    match /page_views/{viewId} {
      allow create: if isValidId(viewId) && isValidPageView(incoming());
      
      allow read, list, delete: if isAdmin();
    }
  }
}
