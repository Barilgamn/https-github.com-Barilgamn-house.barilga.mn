{
  "entities": {
    "AdminUser": {
      "title": "Admin User",
      "description": "A user with administrative access",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["email", "addedAt"]
    },
    "BoothBooking": {
      "title": "Booth Booking",
      "description": "Information about a company booking a booth at the expo.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "The name of the company." },
        "contactName": { "type": "string", "description": "The name of the contact person." },
        "phone": { "type": "string", "description": "The phone number of the contact person." },
        "boothId": { "type": "string", "description": "The ID of the booth being booked." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the booking was created." }
      },
      "required": ["companyName", "contactName", "phone", "boothId", "createdAt"]
    },
    "VisitorRegistration": {
      "title": "Visitor Registration",
      "description": "Information about a visitor registering for the expo.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "The first name of the visitor." },
        "lastName": { "type": "string", "description": "The last name of the visitor." },
        "phone": { "type": "string", "description": "The phone number of the visitor." },
        "email": { "type": "string", "format": "email", "description": "The email address of the visitor." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the registration was created." }
      },
      "required": ["firstName", "lastName", "phone", "email", "createdAt"]
    },
    "Exhibitor": {
      "title": "Exhibitor",
      "description": "An organization that has booked a booth and will be displayed on the website.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "activity": { "type": "string" },
        "booth": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "activity", "booth", "createdAt"]
    },
    "PageView": {
      "title": "Page View",
      "description": "Record of a site visit.",
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "userAgent": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["path", "userAgent", "createdAt"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Event schedule items.",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "time", "title", "description", "createdAt"]
    }
  },
  "firestore": {
    "/admins/{email}": {
      "schema": "AdminUser",
      "description": "List of authorized admin emails"
    },
    "/booth_bookings/{bookingId}": {
      "schema": "BoothBooking",
      "description": "Collection of booth booking registrations."
    },
    "/visitor_registrations/{registrationId}": {
      "schema": "VisitorRegistration",
      "description": "Collection of visitor registrations."
    },
    "/exhibitors/{exhibitorId}": {
      "schema": "Exhibitor",
      "description": "Collection of exhibitors (booked booths)."
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Collection of event schedules."
    },
    "/page_views/{viewId}": {
      "schema": "PageView",
      "description": "Collection of page views."
    }
  }
}
